<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Enables the external-display UIWindowScene. The main scene's default
	     configuration is still provided by SwiftUI's WindowGroup; the external
	     role is handled by AppDelegate.configurationForConnecting. Everything
	     else in Info.plist is generated from the INFOPLIST_KEY_* build settings
	     and merged onto this base. -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
	</dict>
	<!-- Plain ws:// to a bare LAN host (e.g. 192.168.1.5:5903) is blocked by
	     App Transport Security by default — NSAllowsLocalNetworking scopes the
	     exception to local-network/literal-IP hosts only; wss:// tunnel
	     connections to real internet hostnames are unaffected and still get
	     full ATS/TLS enforcement. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
